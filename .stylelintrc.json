{
  "plugins": ["stylelint-order"],
  "rules": {
    "order/properties-order": [[{ "properties": ["composes"] }], { "unspecified": "bottomAlphabetical" }],
    "comment-empty-line-before": ["always", { "except": ["first-nested"], "ignore": ["stylelint-commands"] }],
    "rule-empty-line-before": ["always", { "except": ["first-nested"], "ignore": ["after-comment"] }],
    "at-rule-empty-line-before": [
      "always",
      { "except": ["first-nested", "blockless-after-same-name-blockless"], "ignore": ["after-comment"] }
    ]
  }
}
