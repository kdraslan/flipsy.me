{
  "name": "flipsy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx src/ && stylelint \"src/**/*.scss\"",
    "lint:eslint": "eslint --ext .js,.jsx,.ts,.tsx src/ --fix",
    "lint:fix": "eslint --ext .js,.jsx,.ts,.tsx src/ --fix && stylelint \"src/**/*.scss\" --fix",
    "lint:style": "stylelint \"src/**/*.scss\" --fix",
    "preview": "vite preview",
    "sort-package": "npx sort-package-json",
    "start": "vite",
    "typecheck": "tsc --noEmit --ignoreDeprecations 5.0"
  },
  "browserslist": {
    "production": [
      "last 2 versions",
      ">1%",
      "not dead",
      "not IE 11"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "file-saver": "^2.0.5",
    "firebase": "^11.4.0",
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20.17.24",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint-config-prettier": "^9.0.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^3.8.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.0.0",
    "sass": "^1.101.0",
    "sort-package-json": "^3.0.0",
    "stylelint": "^16.26.1",
    "stylelint-order": "^6.0.4",
    "typescript": "^5.1.6",
    "vite": "^6.2.1"
  }
}
